# Copy this file to .env and fill in real values. Never commit .env.

PORT=4000

# Any long random string — used to sign login tokens
JWT_SECRET=sasdfghjkl

# Gmail (or any SMTP) credentials used to send OTP emails
# For Gmail: enable 2FA on the account, then create an "App Password" and use that here —
# your normal Gmail password will NOT work with Nodemailer.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=trinove.corp@gmail.com
SMTP_PASS=admin123
